# ============================================
# TransitMind Sogamoso — Environment Variables
# ============================================
# Copy this file to .env and adjust values

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=transitmind-timegan

# Model Paths
MODEL_DIR=models/timegan
CHECKPOINT_DIR=models/timegan/checkpoints
BEST_MODEL_DIR=models/timegan/best_model

# Data Paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_SYNTHETIC_DIR=data/synthetic
DATA_VALIDATION_DIR=data/validation

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Training
DEVICE=cpu
SEED=42

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# PostgreSQL (for MLflow backend in Docker)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_password
POSTGRES_DB=mlflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ============================================
# Capa 4 — Bots y Grafo Social
# ============================================

# Telegram Bot (obtener en @BotFather)
TELEGRAM_BOT_TOKEN=8480338380:AAFOnJO4tWd3iS88hXhQ_JkUi70qGtc4-O4

# IDs de operadores SecMov (separados por coma)
TELEGRAM_OPERATOR_CHAT_IDS=123456789,987654321

# WhatsApp Business Cloud API (Meta Business)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token

# Layer 4 API
LAYER4_HOST=0.0.0.0
LAYER4_PORT=8003

# Dashboard
DASHBOARD_PORT=8501
