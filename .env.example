# ============================================
# TransitMind Sogamoso — Environment Variables
# ============================================
# Copy this file to .env and adjust values

# MLflow Configuration
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=transitmind-timegan

# Model Paths
MODEL_DIR=models/timegan
CHECKPOINT_DIR=models/timegan/checkpoints
BEST_MODEL_DIR=models/timegan/best_model

# Data Paths
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_SYNTHETIC_DIR=data/synthetic
DATA_VALIDATION_DIR=data/validation

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Training
DEVICE=cpu
SEED=42

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# PostgreSQL (for MLflow backend in Docker)
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_password
POSTGRES_DB=mlflow_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
